<%- include('../partials/header', { activePage: 'residents' }) %>

<div class="page-hero hero-residents">
  <div class="hero-content">
    <h2>Resident Profile 👤</h2>
    <p>Viewing details for Flat <%= resident.flatNo %></p>
  </div>
  <div class="hero-icon">🏠</div>
</div>

<div class="card" style="max-width:600px;margin:0 auto;">
  <div class="card-header">
    <h5><%= resident.name %></h5>
    <a href="/admin/residents" class="btn btn-outline btn-sm">← Back</a>
  </div>
  <div class="card-body">
    <div style="display:flex;align-items:center;gap:20px;margin-bottom:24px;padding-bottom:20px;border-bottom:1px solid #eee;">
      <div style="width:72px;height:72px;border-radius:50%;background:linear-gradient(135deg,#6C63FF,#a78bfa);display:flex;align-items:center;justify-content:center;color:#fff;font-size:28px;font-weight:800;flex-shrink:0;">
        <%= resident.name.charAt(0).toUpperCase() %>
      </div>
      <div>
        <h3 style="margin:0;font-size:20px;color:#1A1A2E;"><%= resident.name %></h3>
        <p style="margin:4px 0;color:#888;font-size:13px;"><%= resident.email %></p>
        <span class="badge badge-resident">🏠 Resident</span>
      </div>
    </div>

    <div class="form-grid-2" style="gap:16px;">
      <div style="background:#f8f8ff;border-radius:12px;padding:14px;">
        <div style="font-size:11px;color:#888;font-weight:600;text-transform:uppercase;letter-spacing:0.8px;margin-bottom:4px;">Flat Number</div>
        <div style="font-size:16px;font-weight:700;color:#1A1A2E;"><%= resident.flatNo || 'Not set' %></div>
      </div>
      <div style="background:#f8f8ff;border-radius:12px;padding:14px;">
        <div style="font-size:11px;color:#888;font-weight:600;text-transform:uppercase;letter-spacing:0.8px;margin-bottom:4px;">Floor</div>
        <div style="font-size:16px;font-weight:700;color:#1A1A2E;"><%= resident.floor || 'Not set' %></div>
      </div>
      <div style="background:#f8f8ff;border-radius:12px;padding:14px;">
        <div style="font-size:11px;color:#888;font-weight:600;text-transform:uppercase;letter-spacing:0.8px;margin-bottom:4px;">Phone</div>
        <div style="font-size:16px;font-weight:700;color:#1A1A2E;"><%= resident.phone || 'Not set' %></div>
      </div>
      <div style="background:#f8f8ff;border-radius:12px;padding:14px;">
        <div style="font-size:11px;color:#888;font-weight:600;text-transform:uppercase;letter-spacing:0.8px;margin-bottom:4px;">Family Members</div>
        <div style="font-size:16px;font-weight:700;color:#1A1A2E;">👨‍👩‍👧 <%= resident.familyMembers %></div>
      </div>
      <div style="background:#f8f8ff;border-radius:12px;padding:14px;">
        <div style="font-size:11px;color:#888;font-weight:600;text-transform:uppercase;letter-spacing:0.8px;margin-bottom:4px;">Member Since</div>
        <div style="font-size:15px;font-weight:700;color:#1A1A2E;"><%= new Date(resident.createdAt).toDateString() %></div>
      </div>
      <div style="background:#f8f8ff;border-radius:12px;padding:14px;">
        <div style="font-size:11px;color:#888;font-weight:600;text-transform:uppercase;letter-spacing:0.8px;margin-bottom:4px;">Status</div>
        <div><span class="badge <%= resident.isActive ? 'badge-paid' : 'badge-high' %>"><%= resident.isActive ? '✅ Active' : '❌ Inactive' %></span></div>
      </div>
    </div>

    <div style="margin-top:20px;display:flex;gap:12px;justify-content:flex-end;">
      <form action="/admin/residents/<%= resident._id %>?_method=DELETE" method="POST" style="display:inline;">
        <button type="submit" class="btn btn-danger" onclick="return confirm('Delete this resident permanently?')">🗑️ Delete Resident</button>
      </form>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
