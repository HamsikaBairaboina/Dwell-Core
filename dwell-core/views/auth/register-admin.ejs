<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Register Admin - Dwell Core</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <style>
    .auth-page { background: linear-gradient(135deg, #1A1A2E 0%, #16213E 50%, #0F3460 100%); }
    .auth-page::before { content: '👑'; }
    .admin-badge {
      display: inline-flex; align-items: center; gap: 6px;
      background: linear-gradient(135deg, rgba(108,99,255,0.2), rgba(155,89,182,0.2));
      border: 1px solid rgba(108,99,255,0.4);
      color: #a78bfa; padding: 6px 14px; border-radius: 20px;
      font-size: 12px; font-weight: 600; margin-bottom: 20px;
    }
    .secret-note {
      background: rgba(243,156,18,0.1);
      border: 1px solid rgba(243,156,18,0.3);
      border-radius: 10px;
      padding: 12px 14px;
      font-size: 12px;
      color: #E67E22;
      margin-bottom: 20px;
      display: flex; gap: 8px; align-items: flex-start;
    }
  </style>
</head>
<body>
<div class="auth-page">
  <div class="auth-card" style="max-width:480px;">

    <div class="auth-logo">
      <div class="logo-icon" style="background:linear-gradient(135deg,#1A1A2E,#0F3460);">👑</div>
      <h3>Dwell Core</h3>
      <p>Administrator Registration</p>
    </div>

    <div style="text-align:center;">
      <span class="admin-badge">👑 Admin Account Setup</span>
    </div>

    <% if (success && success.length > 0) { %>
      <div class="alert alert-success">✅ <%= success[0] %></div>
    <% } %>
    <% if (error && error.length > 0) { %>
      <div class="alert alert-error">❌ <%= error[0] %></div>
    <% } %>

    <div class="secret-note">
      ⚠️ <span>This page is restricted. You must enter the <strong>Admin Secret Key</strong> set in your <code>.env</code> file (<code>ADMIN_SECRET</code>) to create an admin account.</span>
    </div>

    <form action="/auth/register-admin" method="POST">
      <div class="form-group">
        <label class="form-label">Full Name *</label>
        <input type="text" name="name" class="form-control" placeholder="e.g., Building Manager" required autofocus>
      </div>
      <div class="form-group">
        <label class="form-label">Email Address *</label>
        <input type="email" name="email" class="form-control" placeholder="admin@dwellcore.com" required>
      </div>
      <div class="form-group">
        <label class="form-label">Phone Number</label>
        <input type="tel" name="phone" class="form-control" placeholder="+91 9876543210">
      </div>
      <div class="form-group">
        <label class="form-label">Department / Role Title</label>
        <input type="text" name="department" class="form-control" placeholder="e.g., Society Management">
      </div>
      <div class="form-grid-2">
        <div class="form-group">
          <label class="form-label">Password *</label>
          <input type="password" name="password" class="form-control" placeholder="Min. 6 characters" required minlength="6">
        </div>
        <div class="form-group">
          <label class="form-label">Confirm Password *</label>
          <input type="password" name="confirmPassword" class="form-control" placeholder="Repeat password" required>
        </div>
      </div>
      <div class="form-group">
        <label class="form-label">🔑 Admin Secret Key *</label>
        <input type="password" name="adminSecret" class="form-control" placeholder="Enter the secret key from .env" required>
        <small style="color:#888;font-size:11px;margin-top:4px;display:block;">Default (change in .env): <code>dwellcore_admin_2024</code></small>
      </div>
      <button type="submit" class="btn btn-primary w-100" style="justify-content:center;padding:12px;background:linear-gradient(135deg,#1A1A2E,#0F3460);">
        👑 Create Admin Account
      </button>
    </form>

    <div class="auth-link">
      <a href="/auth/login">← Back to Login</a>
      &nbsp;•&nbsp;
      <a href="/auth/register">Register as Resident</a>
    </div>
  </div>
</div>
<script>
setTimeout(() => {
  document.querySelectorAll('.alert').forEach(a => { a.style.opacity='0'; a.style.transition='opacity 0.5s'; setTimeout(()=>a.remove(),500); });
}, 4000);
</script>
</body>
</html>
