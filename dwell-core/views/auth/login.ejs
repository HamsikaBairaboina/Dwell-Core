<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
<div class="auth-page">
  <div class="auth-card">
    <div class="auth-logo">
      <div class="logo-icon">🏢</div>
      <h3>Dwell Core</h3>
      <p>Smart Apartment Management System</p>
    </div>

    <% if (success && success.length > 0) { %>
      <div class="alert alert-success">✅ <%= success[0] %></div>
    <% } %>
    <% if (error && error.length > 0) { %>
      <div class="alert alert-error">❌ <%= error[0] %></div>
    <% } %>

    <h4>Welcome Back 👋</h4>

    <form action="/auth/login" method="POST">
      <div class="form-group">
        <label class="form-label">Email Address</label>
        <input type="email" name="email" class="form-control" placeholder="you@example.com" required autofocus>
      </div>
      <div class="form-group">
        <label class="form-label">Password</label>
        <input type="password" name="password" class="form-control" placeholder="••••••••" required>
      </div>
      <button type="submit" class="btn btn-primary w-100" style="justify-content:center; padding:12px;">
        <i class="fas fa-sign-in-alt"></i> Login to Dashboard
      </button>
    </form>

    <div class="auth-link">
      Don't have an account? <a href="/auth/register">Register as Resident</a>
    </div>
    <div class="auth-link" style="margin-top:8px;">
      Are you an admin? <a href="/auth/register-admin" style="color:#9B59B6;">Register as Admin 👑</a>
    </div>

    <div style="margin-top:20px; padding:14px; background:#f8f8ff; border-radius:10px; font-size:12px; color:#888;">
      <strong>Demo Accounts:</strong><br>
      Admin: admin@dwellcore.com / admin123<br>
      Resident: resident@dwellcore.com / resident123
    </div>
  </div>
</div>
<script>
setTimeout(() => {
  document.querySelectorAll('.alert').forEach(a => { a.style.opacity='0'; a.style.transition='opacity 0.5s'; setTimeout(()=>a.remove(),500); });
}, 4000);
</script>
</body>
</html>
